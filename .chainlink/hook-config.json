{
  "tracking_mode": "relaxed",
  "blocked_git_commands": [
    "git reset --hard", "git clean -f", "git checkout .",
    "git restore .", "git push --force", "git push -f"
  ],
  "allowed_bash_prefixes": [
    "chainlink ",
    "git ", "cargo ", "npm ", "npx ",
    "tsc", "node ", "python ",
    "ls", "dir", "pwd", "echo", "cat ", "mkdir ", "touch "
  ]
}
